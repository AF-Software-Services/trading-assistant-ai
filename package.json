{
  "name": "trading-assistant-ai",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "dev:remote": "wrangler dev --remote",
    "dev:ui": "cd ui && npm run dev",
    "deploy": "npm run build:ui && wrangler deploy",
    "build:ui": "cd ui && npm install && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.15.0",
    "hono": "^4.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260721.1",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "wrangler": "^4.113.0"
  },
  "allowScripts": {
    "esbuild@0.21.5": true,
    "esbuild@0.17.19": true,
    "workerd@1.20250718.0": true
  }
}
